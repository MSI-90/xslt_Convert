<Window x:Class="xslt_GUI.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:xslt_GUI"
        mc:Ignorable="d"
        Title="MainWindow" Height="450" Width="600"
        MinHeight="250" MinWidth="200">
    <Grid>
        <Button Content="Обработать" HorizontalAlignment="Left" Margin="18,65,0,0" VerticalAlignment="Top" Click="Button_Click_1"/>
        <DataGrid x:Name="grid" Margin="10,100,10,10"/>
        <Button Content="Выбрать файл для преобразования" HorizontalAlignment="Left" Margin="10,10,0,0" VerticalAlignment="Top" RenderTransformOrigin="-0.601,-0.108" Width="213" Click="Button_Click"/>
        <TextBox x:Name="filePathTextBox" HorizontalAlignment="Left" Margin="279,12,0,0" TextWrapping="Wrap" Text="TextBox" VerticalAlignment="Top" Width="281"/>
    </Grid>
</Window>
